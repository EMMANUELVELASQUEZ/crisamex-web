# ============================================================
# CRISAMEX — Seguridad Enterprise .htaccess
# ============================================================

Options -Indexes -ExecCGI
ServerSignature Off

# ── ROUTER PHP ──────────────────────────────────────────────
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# ── FORZAR HTTPS ─────────────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^localhost
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ── BLOQUEAR ARCHIVOS SENSIBLES ──────────────────────────────
<FilesMatch "(\.(env|sql|log|bak|old|conf|ini|sh|bash|git|yml|yaml|xml|lock)|composer\.(json|lock)|package\.json|webpack\.config|Dockerfile|docker-compose)$">
    Require all denied
</FilesMatch>

# ── BLOQUEAR CARPETAS INTERNAS ───────────────────────────────
RedirectMatch 403 ^/src/
RedirectMatch 403 ^/database/
RedirectMatch 403 ^/docker/
RedirectMatch 403 ^/vendor/
RedirectMatch 403 ^/\.git

# ── HEADERS DE SEGURIDAD ─────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# ── PROTEGER CONTRA ATAQUES COMUNES ──────────────────────────
# Bloquear user agents maliciosos
RewriteCond %{HTTP_USER_AGENT} (havij|nikto|sqlmap|nmap|masscan|zgrab|nessus|openvas|burpsuite|dirbuster|gobuster|wfuzz|acunetix|appscan|webinspect) [NC]
RewriteRule .* - [F,L]

# Bloquear inyección SQL básica en URL
RewriteCond %{QUERY_STRING} (union.*select|select.*from|insert.*into|delete.*from|drop.*table|update.*set|exec.*\(|cast.*\(|convert.*\() [NC]
RewriteRule .* - [F,L]

# Bloquear XSS en URL
RewriteCond %{QUERY_STRING} (<script|javascript:|vbscript:|onload=|onerror=|onclick=) [NC]
RewriteRule .* - [F,L]

# Bloquear path traversal
RewriteCond %{REQUEST_URI} \.\./
RewriteRule .* - [F,L]

# Bloquear acceso a archivos ocultos
RewriteCond %{REQUEST_URI} /\. [NC]
RewriteRule .* - [F,L]

# Bloquear ataques de fuerza bruta al login (rate limitado en PHP)
RewriteCond %{REQUEST_URI} ^/(admin/login|portal/login)$ [NC]
RewriteCond %{REQUEST_METHOD} POST
RewriteRule .* - [E=LOGIN_ATTEMPT:1]

# ── CACHÉ DE ASSETS ESTÁTICOS ────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 3 months"
    ExpiresByType image/jpg "access plus 3 months"
    ExpiresByType image/jpeg "access plus 3 months"
    ExpiresByType image/svg+xml "access plus 3 months"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# ── COMPRESIÓN GZIP ──────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
    AddOutputFilterByType DEFLATE image/svg+xml application/json
</IfModule>

# ── ERRORES PERSONALIZADOS ───────────────────────────────────
ErrorDocument 403 /403.html
ErrorDocument 404 /404.html
ErrorDocument 500 /500.html

# ── DESHABILITAR MÉTODOS HTTP PELIGROSOS ─────────────────────
<LimitExcept GET POST HEAD>
    Require all denied
</LimitExcept>
